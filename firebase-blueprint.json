{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student", "admin"] },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "firstName", "lastName", "role"]
    },
    "Session": {
      "title": "Session",
      "description": "A learning session (audio analysis or PDF analysis)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userFullName": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "pdf"] },
        "result": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "result", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Learning sessions created by students or teachers"
    }
  }
}
